# Nepal Civic Intelligence Graph 3.0 — Environment Variables
# Copy to .env and fill in production values

# ── Kafka ──────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── Neo4j ──────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nepal_civic_2026

# ── PostgreSQL (PostGIS) ──────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ncig
PG_USER=ncig_admin
PG_PASSWORD=nepal_civic_2026

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://:nepal_civic_2026@localhost:6379

# ── Elasticsearch ──────────────────────────────────────────────
ES_NODE=http://localhost:9200

# ── MinIO (Object Storage) ────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=ncig_minio
MINIO_SECRET_KEY=nepal_civic_2026

# ── API Gateway ────────────────────────────────────────────────
JWT_SECRET=ncig_jwt_secret_2026_change_in_production
CORS_ORIGIN=http://localhost:5173

# ── AI Services ────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Service Ports ──────────────────────────────────────────────
API_GATEWAY_PORT=3000
SCRAPER_PORT=3001
CLASSIFIER_PORT=8001
SUMMARIZER_PORT=8002
GRAPH_PORT=4001
QUERY_PORT=4002
ALERT_PORT=4003
CHATBOT_PORT=4004
POLICY_PORT=4005
SCORER_PORT=4006
SIMULATION_PORT=4007
DEDUP_PORT=4008
PREDICTION_PORT=8005

# ── Mapbox (Frontend) ─────────────────────────────────────────
VITE_MAPBOX_TOKEN=your_mapbox_token_here
